# Copy this file to .env.local and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the client app.

VITE_DEVIN_API_KEY=
VITE_DEVIN_ORG_ID=
VITE_GITHUB_SCOPE=

# Set these to enable GitHub OAuth mode in the frontend.
# These are required for GitHub sync in the UI.
VITE_GITHUB_OAUTH_START_URL=/api/github/oauth/start
VITE_GITHUB_OAUTH_TOKEN_URL=/api/github/oauth/token
VITE_GITHUB_OAUTH_DISCONNECT_URL=/api/github/oauth/disconnect

# Backend OAuth server settings (used by `npm run oauth:server`).
GITHUB_OAUTH_SERVER_PORT=8787
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8787/api/github/oauth/callback
GITHUB_OAUTH_SCOPES=repo
GITHUB_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/
GITHUB_OAUTH_ALLOWED_ORIGIN=http://localhost:5173
GITHUB_OAUTH_COOKIE_SECURE=false
GITHUB_OAUTH_COOKIE_DOMAIN=
