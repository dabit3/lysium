# Copy this file to .env.local and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the client app.

# Your Devin API credentials (required to use Devin features)
VITE_DEVIN_API_KEY=
VITE_DEVIN_ORG_ID=
VITE_GITHUB_SCOPE=

# ── Local dev OAuth server (npm run dev:oauth) ────────────────────────────────
# Used only when running the local Node OAuth server alongside `npm run dev`.
GITHUB_OAUTH_SERVER_PORT=8787
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8787/api/github/oauth/callback
GITHUB_OAUTH_SCOPES=repo
GITHUB_OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/
GITHUB_OAUTH_ALLOWED_ORIGIN=http://localhost:5173
GITHUB_OAUTH_COOKIE_SECURE=false
GITHUB_OAUTH_COOKIE_DOMAIN=

# ── Vercel production OAuth (set these in the Vercel dashboard, not here) ─────
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=     https://your-app.vercel.app/api/github/oauth/callback
# GITHUB_OAUTH_SCOPES=           repo
# GITHUB_OAUTH_SUCCESS_REDIRECT_URL= https://your-app.vercel.app/
# GITHUB_OAUTH_ALLOWED_ORIGIN=   https://your-app.vercel.app
# GITHUB_OAUTH_COOKIE_SECURE=    true
# GITHUB_OAUTH_COOKIE_SECRET=    (generate: openssl rand -hex 32)
